// Money Pilot — database schema
// Phase 3+ wires these models to the app. Phase 1 (homepage) does not require a DB.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Accounts & auth ──────────────────────────────────────
model User {
  // id equals the Supabase Auth user UUID (set explicitly on sync, no default)
  id        String   @id
  email     String   @unique
  name      String?
  avatarUrl String?
  role      Role     @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  profile       Profile?
  accounts      FinancialAccount[]
  transactions  Transaction[]
  budgetCategories BudgetCategory[]
  goals         Goal[]
  debts         Debt[]
  bills         Bill[]
  healthScores  HealthScoreSnapshot[]
  conversations CoachConversation[]
  lessonProgress LessonProgress[]
  lessonCompletions LessonCompletion[]
  achievements  UserAchievement[]
  unlockedAchievements UnlockedAchievement[]
  articles      Article[]
  subscriptions Subscription[]
}

enum Role {
  USER
  ADMIN
}

model Profile {
  id             String   @id @default(cuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  monthlyIncome  Decimal  @default(0) @db.Decimal(12, 2)
  currency       String   @default("USD")
  riskTolerance  String?  // conservative | moderate | aggressive
  onboardedAt    DateTime?
  xp             Int      @default(0)
  level          Int      @default(1)
  learningStreak Int      @default(0)
  budgetStreak   Int      @default(0)
  updatedAt      DateTime @updatedAt
}

// ─── Financial data (manual entry) ────────────────────────
model FinancialAccount {
  id        String      @id @default(cuid())
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  type      AccountType
  balance   Decimal     @default(0) @db.Decimal(14, 2)
  // Credit limit for CREDIT accounts — used to compute credit utilization.
  creditLimit Decimal?  @db.Decimal(14, 2)
  createdAt DateTime    @default(now())
  transactions Transaction[]
}

enum AccountType {
  CHECKING
  SAVINGS
  CREDIT
  INVESTMENT
  CASH
  LOAN
}

model Transaction {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  accountId   String?
  account     FinancialAccount? @relation(fields: [accountId], references: [id], onDelete: SetNull)
  amount      Decimal  @db.Decimal(12, 2) // negative = expense, positive = income
  category    String
  description String?
  date        DateTime @default(now())
  createdAt   DateTime @default(now())

  @@index([userId, date])
}

model BudgetCategory {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  planned   Decimal  @default(0) @db.Decimal(12, 2)
  color     String   @default("#3b82f6")
  sortOrder Int      @default(0)
  isCustom  Boolean  @default(false)
}

model Goal {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name          String
  targetAmount  Decimal   @db.Decimal(12, 2)
  currentAmount Decimal   @default(0) @db.Decimal(12, 2)
  targetDate    DateTime?
  createdAt     DateTime  @default(now())
}

model Debt {
  id            String  @id @default(cuid())
  userId        String
  user          User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  name          String
  balance       Decimal @db.Decimal(12, 2)
  interestRate  Decimal @db.Decimal(5, 2)
  minimumPayment Decimal @db.Decimal(12, 2)
  createdAt     DateTime @default(now())
}

model Bill {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  amount    Decimal  @db.Decimal(12, 2)
  dueDay    Int // day of month 1-31
  isPaid    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model HealthScoreSnapshot {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  score     Int
  factors   Json // { savingsRate, debtRatio, emergencyFund, ... }
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

// ─── AI coach ─────────────────────────────────────────────
model CoachConversation {
  id        String         @id @default(cuid())
  userId    String
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String?
  createdAt DateTime       @default(now())
  messages  CoachMessage[]
}

model CoachMessage {
  id             String   @id @default(cuid())
  conversationId String
  conversation   CoachConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String // user | assistant
  content        String   @db.Text
  createdAt      DateTime @default(now())
}

// ─── Learning & gamification ───────────────────────────────
// Course/Lesson/LessonProgress below are reserved for a future admin-managed
// CMS version of the Learning Center. The MVP Learning Center instead keeps
// lesson content as static, versioned data (lib/learning-content.ts) and
// tracks per-user progress with the lighter-weight LessonCompletion model,
// which needs no DB-seeded content and works immediately.
model LessonCompletion {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lessonSlug  String // "<courseSlug>/<lessonSlug>"
  quizScore   Int? // percent 0-100
  completedAt DateTime @default(now())

  @@unique([userId, lessonSlug])
}

model Course {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  level       String // beginner | intermediate | advanced
  summary     String?
  sortOrder   Int      @default(0)
  lessons     Lesson[]
}

model Lesson {
  id            String   @id @default(cuid())
  courseId      String
  course        Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  slug          String
  title         String
  body          String?  @db.Text
  estMinutes    Int      @default(10)
  difficulty    String   @default("easy")
  sortOrder     Int      @default(0)
  progress      LessonProgress[]

  @@unique([courseId, slug])
}

model LessonProgress {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lessonId    String
  lesson      Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  completedAt DateTime?
  quizScore   Int?

  @@unique([userId, lessonId])
}

// UnlockedAchievement mirrors the LessonCompletion pattern: achievement
// definitions (title, description, unlock condition) live as static code in
// lib/achievements.ts rather than DB rows, since unlock logic inherently
// belongs in code and this avoids needing to seed the Achievement table.
// Achievement/UserAchievement below stay reserved for a future admin CMS.
model UnlockedAchievement {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievementKey String
  unlockedAt     DateTime @default(now())

  @@unique([userId, achievementKey])
}

model Achievement {
  id          String @id @default(cuid())
  key         String @unique
  title       String
  description String
  icon        String @default("trophy")
  xp          Int    @default(50)
  users       UserAchievement[]
}

model UserAchievement {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievementId String
  achievement   Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)
  earnedAt      DateTime @default(now())

  @@unique([userId, achievementId])
}

// ─── Admin panel ────────────────────────────────────────────
// Unlike lessons/calculators/achievements (static code, by design — see
// notes above), articles and notifications have no static-content
// precedent to conflict with, so they're real DB-backed CRUD content.
model Article {
  id        String   @id @default(cuid())
  slug      String   @unique
  title     String
  excerpt   String?
  body      String   @db.Text
  published Boolean  @default(false)
  authorId  String?
  author    User?    @relation(fields: [authorId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Notification {
  id        String   @id @default(cuid())
  message   String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

// ─── Tools ──────────────────────────────────────────────────
model Subscription {
  id              String         @id @default(cuid())
  userId          String
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  name            String
  amount          Decimal        @db.Decimal(12, 2)
  billingCycle    BillingCycle   @default(MONTHLY)
  nextChargeDate  DateTime
  isActive        Boolean        @default(true)
  createdAt       DateTime       @default(now())
}

enum BillingCycle {
  WEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
}
